{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.cjs"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/index.cjs"
    },
    {
      "source": "/robots.txt",
      "destination": "/api/index.cjs"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        },
        {
          "key": "Content-Security-Policy",
          "value": "script-src 'self' 'unsafe-inline' 'unsafe-eval' https://*.tawk.to https://*.google.com https://*.gstatic.com;"
        }
      ]
    }
  ]
}
