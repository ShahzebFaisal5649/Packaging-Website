# ─────────────────────────────────────────────────────────────────────────────
# Design Custom Box — Environment Variables
# Copy this file to .env and fill in your values.
# Set ALL of these in Vercel dashboard for both Production & Preview.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxx.mongodb.net/designcustombox?retryWrites=true&w=majority

# ── Authentication ────────────────────────────────────────────────────────────
JWT_SECRET=your_very_long_random_secret_string_here

# ── Email (Gmail SMTP — use App Password, NOT regular Gmail password) ─────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=Designcustombox@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx
EMAIL_FROM=Designcustombox@gmail.com

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_or_test_key_here
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_key_here

# ── Site URLs (set DIFFERENT values per environment in Vercel) ────────────────
# Production:  https://designcustombox.com
# Preview:     https://novapack-custom-box.vercel.app
CLIENT_URL=https://designcustombox.com
NEXTAUTH_URL=https://designcustombox.com
NEXT_PUBLIC_SITE_URL=https://designcustombox.com
NEXT_PUBLIC_APP_URL=https://designcustombox.com

# ── Vite Frontend Variables (prefixed with VITE_) ─────────────────────────────
VITE_API_URL=/api
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ── Live Chat (Tawk.to) ───────────────────────────────────────────────────────
VITE_TAWK_PROPERTY_ID=your_tawk_property_id
VITE_TAWK_WIDGET_ID=your_tawk_widget_id

# ── AI Chat ───────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ── Local Development Only ───────────────────────────────────────────────────
PORT=5000
